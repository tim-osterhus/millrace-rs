{
  "schema_version": "1.0",
  "kind": "graph_loop",
  "loop_id": "planning.standard",
  "plane": "planning",
  "nodes": [
    {"node_id": "planner", "stage_kind_id": "planner"},
    {"node_id": "manager", "stage_kind_id": "manager"},
    {"node_id": "mechanic", "stage_kind_id": "mechanic"},
    {"node_id": "auditor", "stage_kind_id": "auditor"},
    {"node_id": "arbiter", "stage_kind_id": "arbiter"}
  ],
  "entry_nodes": [
    {"entry_key": "spec", "node_id": "planner"},
    {"entry_key": "incident", "node_id": "auditor"}
  ],
  "edges": [
    {"edge_id": "planner-complete-to-manager", "from_node_id": "planner", "to_node_id": "manager", "on_outcomes": ["PLANNER_COMPLETE"]},
    {"edge_id": "planner-blocked-to-mechanic", "from_node_id": "planner", "to_node_id": "mechanic", "on_outcomes": ["BLOCKED"]},
    {"edge_id": "manager-complete-to-terminal-manager-complete", "from_node_id": "manager", "terminal_state_id": "manager_complete", "on_outcomes": ["MANAGER_COMPLETE"], "kind": "terminal"},
    {"edge_id": "manager-blocked-to-mechanic", "from_node_id": "manager", "to_node_id": "mechanic", "on_outcomes": ["BLOCKED"]},
    {"edge_id": "mechanic-complete-to-planner", "from_node_id": "mechanic", "to_node_id": "planner", "on_outcomes": ["MECHANIC_COMPLETE"]},
    {"edge_id": "mechanic-blocked-to-mechanic", "from_node_id": "mechanic", "to_node_id": "mechanic", "on_outcomes": ["BLOCKED"]},
    {"edge_id": "auditor-complete-to-planner", "from_node_id": "auditor", "to_node_id": "planner", "on_outcomes": ["AUDITOR_COMPLETE"]},
    {"edge_id": "auditor-blocked-to-mechanic", "from_node_id": "auditor", "to_node_id": "mechanic", "on_outcomes": ["BLOCKED"]},
    {"edge_id": "arbiter-complete-to-terminal-arbiter-complete", "from_node_id": "arbiter", "terminal_state_id": "arbiter_complete", "on_outcomes": ["ARBITER_COMPLETE"], "kind": "terminal"},
    {"edge_id": "arbiter-remediation-needed-to-terminal-remediation-needed", "from_node_id": "arbiter", "terminal_state_id": "remediation_needed", "on_outcomes": ["REMEDIATION_NEEDED"], "kind": "terminal"},
    {"edge_id": "arbiter-blocked-to-terminal-blocked", "from_node_id": "arbiter", "terminal_state_id": "blocked", "on_outcomes": ["BLOCKED"], "kind": "terminal"}
  ],
  "terminal_states": [
    {"terminal_state_id": "manager_complete", "terminal_class": "success", "writes_status": "MANAGER_COMPLETE", "emits_artifacts": ["stage_result", "task_cards"]},
    {"terminal_state_id": "arbiter_complete", "terminal_class": "success", "writes_status": "ARBITER_COMPLETE", "emits_artifacts": ["stage_result", "verdict", "report"]},
    {"terminal_state_id": "remediation_needed", "terminal_class": "followup_needed", "writes_status": "REMEDIATION_NEEDED", "emits_artifacts": ["stage_result", "incident_report", "verdict", "report"]},
    {"terminal_state_id": "blocked", "terminal_class": "blocked", "writes_status": "BLOCKED", "emits_artifacts": ["stage_result", "report"]}
  ],
  "dynamic_policies": {
    "resume_policies": [
      {
        "policy_id": "planning.mechanic.resume",
        "source_node_id": "mechanic",
        "on_outcome": "MECHANIC_COMPLETE",
        "default_target_node_id": "planner",
        "metadata_stage_keys": ["resume_stage"],
        "disallowed_target_node_ids": ["mechanic"]
      }
    ],
    "threshold_policies": [
      {
        "policy_id": "planning.blocked.recovery",
        "source_node_ids": ["planner", "manager", "auditor", "mechanic"],
        "on_outcome": "BLOCKED",
        "counter_name": "mechanic_attempt_count",
        "threshold": 2,
        "exhausted_terminal_state_id": "blocked"
      }
    ]
  },
  "completion_behavior": {
    "trigger": "backlog_drained",
    "readiness_rule": "no_open_lineage_work",
    "target_node_id": "arbiter",
    "request_kind": "closure_target",
    "target_selector": "active_closure_target",
    "rubric_policy": "reuse_or_create",
    "blocked_work_policy": "suppress",
    "skip_if_already_closed": true,
    "on_pass_terminal_state_id": "arbiter_complete",
    "on_gap_terminal_state_id": "remediation_needed",
    "create_incident_on_gap": true
  }
}
