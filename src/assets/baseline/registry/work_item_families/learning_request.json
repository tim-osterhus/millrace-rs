{
  "schema_version": "1.0",
  "kind": "work_item_family",
  "family_id": "learning_request",
  "plane": "learning",
  "entry_key": "learning_request",
  "display_name": "Learning Request",
  "document_kind": "learning_request",
  "runtime_relative_dir": "learning/requests",
  "file_extension": ".md",
  "schema_id": "learning_request_document_v1",
  "document_adapter_id": "builtin_markdown_v1",
  "queue_dirs": {
    "queue": "learning/requests/queue",
    "active": "learning/requests/active",
    "done": "learning/requests/done",
    "blocked": "learning/requests/blocked"
  },
  "lifecycle_states": ["queue", "active", "done", "blocked"],
  "claimable_state": "queue",
  "active_state": "active",
  "done_state": "done",
  "blocked_state": "blocked",
  "closure_blocking_states": ["queue", "active", "blocked"],
  "default_entry_key": "learning_request",
  "id_field": "learning_request_id",
  "created_at_field": "created_at",
  "lineage_fields": ["root_spec_id", "root_idea_id"],
  "one_active_policy": "plane",
  "duplicate_policy": "fail",
  "invalid_artifact_policy": "block_source",
  "sort_policy": "created_at_asc",
  "operator_capabilities": ["cancel", "requeue", "retry", "block", "archive", "inspect"]
}
